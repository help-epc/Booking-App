function calculateDomesticPrice(propertyValue, sqm) {
  const value = Number(propertyValue || 0);
  const area = Number(sqm || 0);

  if (value <= 0) {
    return { price: null, status: 'missing', label: 'Select property value', reviewRequired: false };
  }

  if (value <= 999000) {
    return { price: 60, status: 'priced', label: 'Up to £999,000', reviewRequired: false };
  }

  if (value <= 1999999) {
    return { price: 80, status: 'priced', label: '£1,000,000 to £1,999,999', reviewRequired: false };
  }

  if (value <= 2999999) {
    return { price: 110, status: 'priced', label: '£2,000,000 to £2,999,999', reviewRequired: false };
  }

  if (value <= 3999999) {
    return { price: 150, status: 'priced', label: '£3,000,000 to £3,999,999', reviewRequired: false };
  }

  if (!area) {
    return { price: null, status: 'review', label: 'Over £4,000,000 — square meterage required', reviewRequired: true };
  }

  if (area <= 150) {
    return { price: 180, status: 'priced', label: 'Over £4,000,000, 100–150 m²', reviewRequired: false };
  }

  if (area <= 300) {
    return { price: 240, status: 'priced', label: 'Over £4,000,000, 151–300 m²', reviewRequired: false };
  }

  if (area <= 500) {
    return { price: 400, status: 'priced', label: 'Over £4,000,000, 301–500 m²', reviewRequired: false };
  }

  if (area <= 750) {
    return { price: 450, status: 'priced', label: 'Over £4,000,000, 501–750 m²', reviewRequired: false };
  }

  if (area <= 10000) {
    return { price: 450, status: 'priced', label: 'Over £4,000,000, 751–10,000 m²', reviewRequired: false };
  }

  return { price: null, status: 'review', label: 'Large residential property — review required', reviewRequired: true };
}

function calculateCommercialPrice(sqm) {
  const area = Number(sqm || 0);

  if (!area) {
    return { price: null, status: 'missing', label: 'Enter commercial floor area', reviewRequired: true };
  }

  if (area <= 100) {
    return { price: 180, status: 'priced', label: '0–100 m²', reviewRequired: false };
  }

  if (area <= 200) {
    return { price: 215, status: 'priced', label: '101–200 m²', reviewRequired: false };
  }

  if (area <= 300) {
    return { price: 255, status: 'priced', label: '201–300 m²', reviewRequired: false };
  }

  if (area <= 400) {
    return { price: 305, status: 'priced', label: '301–400 m²', reviewRequired: false };
  }

  if (area <= 500) {
    return { price: 355, status: 'priced', label: '401–500 m²', reviewRequired: false };
  }

  if (area <= 600) {
    return { price: 410, status: 'priced', label: '501–600 m²', reviewRequired: false };
  }

  if (area <= 700) {
    return { price: 455, status: 'priced', label: '601–700 m²', reviewRequired: false };
  }

  if (area <= 800) {
    return { price: 495, status: 'priced', label: '701–800 m²', reviewRequired: false };
  }

  if (area <= 900) {
    return { price: 535, status: 'priced', label: '801–900 m²', reviewRequired: false };
  }

  if (area <= 10000) {
    return { price: null, status: 'review', label: '901 m² to 10,000 m² — custom quote / review required', reviewRequired: true };
  }

  return { price: null, status: 'review', label: 'Large commercial property — custom quote required', reviewRequired: true };
}

function getZone(pc) {
  const clean = (pc || '').replace(/\s/g, '').toUpperCase();
  const prefixes = ['NW','SW','SE','WC','EC','EN','HA','IG','RM','TW','KT','BR','CR','N','E','W'];

  for (const p of prefixes) {
    if (clean.startsWith(p)) {
      return { code: p, ...zones[p] };
    }
  }

  return null;
}

function checkPostcode() {
  const val = document.getElementById('postcode').value.toUpperCase().trim();
  const hint = document.getElementById('postcode-hint');
  const zone = getZone(val);

  if (!val) {
    hint.textContent = 'Enter a London postcode.';
    hint.style.color = 'var(--ink3)';
    return;
  }

  if (zone) {
    state.zoneName = zone.name;
    hint.textContent = '✓ ' + zone.name + ' — we cover this area';
    hint.style.color = 'var(--success)';
  } else {
    hint.textContent = 'This postcode is outside the current London booking zones. You can submit for review.';
    hint.style.color = 'var(--warning)';
  }
}

function selectType(type) {
  state.type = type;
  state.price = null;
  state.reviewRequired = false;
  state.window = null;
  state.date = null;

  document.getElementById('card-domestic').classList.toggle('selected', type === 'Domestic');
  document.getElementById('card-commercial').classList.toggle('selected', type === 'Commercial');

  document.getElementById('domestic-fields').style.display = type === 'Domestic' ? 'block' : 'none';
  document.getElementById('commercial-fields').style.display = type === 'Commercial' ? 'block' : 'none';

  refreshQuote();
}

function refreshQuote() {
  let result = { price: null, status: 'missing', label: 'Complete details', reviewRequired: false };

  if (state.type === 'Domestic') {
    const value = document.getElementById('property_value')?.value;
    const sqm = document.getElementById('domestic_sqm')?.value;

    document.getElementById('domestic-size-field').style.display =
      Number(value) > 4000000 ? 'block' : 'none';

    result = calculateDomesticPrice(value, sqm);
  }

  if (state.type === 'Commercial') {
    result = calculateCommercialPrice(document.getElementById('commercial_sqm')?.value);
  }

  state.price = result.price;
  state.pricingStatus = result.status;
  state.quoteLabel = result.label;
  state.reviewRequired = result.reviewRequired || result.status === 'review';

  const qp = document.getElementById('quote-price');
  const qn = document.getElementById('quote-note');

  if (result.price) {
    qp.textContent = '£' + Number(result.price).toFixed(2);
    qn.textContent =
      result.label +
      (state.type === 'Domestic'
        ? ' · 50% deposit requested before appointment confirmation.'
        : ' · Commercial quote/review workflow.');
  } else if (result.status === 'review') {
    qp.textContent = 'Review required';
    qn.textContent = result.label;
  } else {
    qp.textContent = '—';
    qn.textContent = 'Complete the property details to calculate the quote.';
  }
}

function goToStep(n) {
  const active = document.querySelector('.form-step.active');
  const cur = active && active.id.startsWith('step-')
    ? parseInt(active.id.replace('step-', ''))
    : 1;

  if (n > cur && !validateStep(cur)) {
    return;
  }

  document.querySelectorAll('.form-step').forEach(s => s.classList.remove('active'));
  document.getElementById('step-' + n).classList.add('active');

  document.querySelectorAll('.step-tab').forEach((t, i) => {
    t.classList.remove('active', 'done');
    if (i + 1 === n) t.classList.add('active');
    if (i + 1 < n) t.classList.add('done');
  });

  if (n === 3) {
    buildDateGrid();
    document.getElementById('commercial-review-date-note').style.display =
      state.type === 'Commercial' ? 'block' : 'none';

    document.getElementById('booking-type-note').textContent =
      state.type === 'Domestic'
        ? 'AM/PM booking window'
        : 'Requested date/window for review';
  }

  if (n === 5) {
    populateConfirm();
  }

  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function validateStep(step) {
  if (step === 1) {
    if (!state.type) {
      alert('Please select Domestic or Commercial EPC.');
      return false;
    }
  }

  if (step === 2) {
    const addr = document.getElementById('address').value.trim();
    const pc = document.getElementById('postcode').value.trim();

    if (!addr) return showErr('err-address', 'address');
    if (!pc) return showErr('err-postcode', 'postcode');

    refreshQuote();

    if (state.type === 'Domestic' && !document.getElementById('property_value').value) {
      return showErr('err-property-value', 'property_value');
    }

    if (
      state.type === 'Domestic' &&
      Number(document.getElementById('property_value').value) > 4000000 &&
      !document.getElementById('domestic_sqm').value
    ) {
      return showErr('err-domestic-sqm', 'domestic_sqm');
    }

    if (state.type === 'Commercial' && !document.getElementById('commercial_sqm').value) {
      return showErr('err-commercial-sqm', 'commercial_sqm');
    }

    state.address = addr;
    state.postcode = pc.toUpperCase();

    const zone = getZone(pc);
    state.zoneName = zone ? zone.name : 'Review area';
  }

  if (step === 3) {
    if (!state.date) {
      document.getElementById('err-date').classList.add('show');
      return false;
    }

    if (!state.window) {
      document.getElementById('err-window').classList.add('show');
      return false;
    }
  }

  if (step === 4) {
    if (!document.getElementById('fname').value.trim()) return showErr('err-fname', 'fname');
    if (!document.getElementById('lname').value.trim()) return showErr('err-lname', 'lname');

    const em = document.getElementById('email').value.trim();
    if (!em || !em.includes('@')) return showErr('err-email', 'email');

    if (!document.getElementById('phone').value.trim()) return showErr('err-phone', 'phone');
  }

  return true;
}

function showErr(errId, fieldId) {
  document.getElementById(errId).classList.add('show');
  document.getElementById(fieldId).classList.add('error');
  document.getElementById(fieldId).focus();

  setTimeout(() => {
    document.getElementById(errId).classList.remove('show');
    document.getElementById(fieldId).classList.remove('error');
  }, 3000);

  return false;
}

function buildDateGrid() {
  const grid = document.getElementById('days-grid');
  grid.innerHTML = '';

  const zone = getZone(state.postcode);
  const allowed = zone ? zone.days : [1,2,3,4,5];

  document.getElementById('zone-name').textContent = zone ? zone.name : 'Review area';

  const today = new Date();
  let d = new Date(today);
  d.setDate(d.getDate() + 2);

  let count = 0;
  const days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  while (count < 9) {
    const dow = d.getDay();

    if (allowed.includes(dow)) {
      const iso = d.toISOString().split('T')[0];
      const str = `${days[dow]} ${d.getDate()} ${months[d.getMonth()]}`;

      const slot = document.createElement('div');
      slot.className = 'day-slot';
      slot.innerHTML = `
        <div class="day-name">${days[dow]}</div>
        <div class="day-date">${d.getDate()}</div>
        <div class="day-month">${months[d.getMonth()]}</div>
      `;

      slot.onclick = () => selectDate(slot, iso, str);
      grid.appendChild(slot);
      count++;
    }

    d.setDate(d.getDate() + 1);
  }
}

function selectDate(el, iso, str) {
  document.querySelectorAll('.day-slot').forEach(s => s.classList.remove('selected'));
  el.classList.add('selected');
  state.date = iso;
  state.dateStr = str;
  document.getElementById('err-date').classList.remove('show');
}

