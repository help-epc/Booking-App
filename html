  document.getElementById('cf-phone').textContent = document.getElementById('phone').value;

  document.getElementById('confirm-subtitle').textContent =
    state.type === 'Commercial'
      ? 'This commercial enquiry will be sent for review/quote.'
      : 'This domestic booking request will be sent to the EPC Pro dashboard.';
}

function makeRef() {
  return 'EPC-' + Date.now().toString(36).toUpperCase().slice(-6);
}

function setStatus(type, msg) {
  const box = document.getElementById('submit-status');
  box.className = 'status-box show ' + type;
  box.textContent = msg;
}

function normaliseSource(v) {
  return v || 'Website';
}

async function submitBooking() {
  if (!document.getElementById('terms').checked) {
    alert('Please accept the confirmation box before submitting.');
    return;
  }

  if (!supabaseClient) {
    setStatus('error', 'Supabase is not loaded, so the booking cannot be sent to the dashboard.');
    return;
  }

  const btn = document.getElementById('submit-btn');
  btn.disabled = true;
  btn.textContent = 'Sending...';

  const ref = makeRef();
  const fullName = (document.getElementById('fname').value + ' ' + document.getElementById('lname').value).trim();
  const source = normaliseSource(document.getElementById('source').value);

  const contactPayload = {
    name: fullName,
    email: document.getElementById('email').value.trim(),
    phone: document.getElementById('phone').value.trim(),
    type: document.getElementById('client_type').value,
    created_at: new Date().toISOString()
  };

  try {
    const { data: contact, error: contactErr } = await supabaseClient
      .from('contacts')
      .insert(contactPayload)
      .select()
      .single();

    if (contactErr) throw contactErr;

    const propertyPayload = {
      contact_id: contact.id,
      address: state.address,
      postcode: state.postcode,
      city: 'London',
      created_at: new Date().toISOString()
    };

    const { data: property, error: propertyErr } = await supabaseClient
      .from('properties')
      .insert(propertyPayload)
      .select()
      .single();

    if (propertyErr) throw propertyErr;

    const leadStatus =
      state.type === 'Commercial' || state.reviewRequired
        ? 'Review required'
        : 'Awaiting booking';

    const leadPayload = {
      property_address: state.address,
      postcode: state.postcode,
      source: source,
      status: leadStatus,
      estimated_value: state.price || 0,
      epc_type: state.type,
      created_at: new Date().toISOString()
    };

    const { data: lead, error: leadErr } = await supabaseClient
      .from('leads')
      .insert(leadPayload)
      .select()
      .single();

    if (leadErr) throw leadErr;

    let job = null;

    if (state.type === 'Domestic' && !state.reviewRequired) {
      const deposit = Math.round((state.price * 0.5) * 100) / 100;
      const balance = Math.round((state.price - deposit) * 100) / 100;

      const jobPayload = {
        contact_id: contact.id,
        property_id: property.id,
        reference: ref,
        booking_date: state.date,
        booking_window: state.window,
        provisional_eta: null,
        deposit_amount: deposit,
        deposit_paid: false,
        invoice_issued: false,
        invoice_amount: state.price,
        balance_due: balance,
        epc_type: 'Domestic',
        status: 'Awaiting booking',
        source: source,
        documents: {
          notes: document.getElementById('notes').value,
          lead_id: lead.id,
          pricing_band: state.quoteLabel
        },
        field_status: null,
        created_at: new Date().toISOString()
      };

      const { data: jobData, error: jobErr } = await supabaseClient
        .from('jobs')
        .insert(jobPayload)
        .select()
        .single();

      if (jobErr) throw jobErr;

      job = jobData;
    }

    document.getElementById('booking-ref-num').textContent = job?.reference || ref;

    document.getElementById('success-title').textContent =
      state.type === 'Commercial' || state.reviewRequired
        ? 'Enquiry sent for review'
        : 'Booking request received';

    document.getElementById('success-text').textContent =
      state.type === 'Commercial' || state.reviewRequired
        ? 'Your enquiry has been sent to EPC Pro and will appear in the commercial/review section of the dashboard.'
        : 'Your domestic booking request has been sent to the EPC Pro dashboard. You will be contacted to confirm deposit/payment and appointment details.';

    document.querySelectorAll('.form-step').forEach(s => s.classList.remove('active'));
    document.getElementById('step-success').classList.add('active');
    document.getElementById('progress-wrap').style.display = 'none';
    window.scrollTo({ top: 0, behavior: 'smooth' });

  } catch (err) {
    console.error(err);
    setStatus('error', 'Could not send to the dashboard: ' + (err.message || err));
    btn.disabled = false;
    btn.textContent = 'Submit to EPC Pro';
  }
}

document.querySelectorAll('.field input, .field select, .field textarea').forEach(el => {
  el.addEventListener('input', () => {
    el.classList.remove('error');
  });
});
</script>
</body>
</html>
