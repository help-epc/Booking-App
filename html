<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Book an EPC Assessment — The EPC Pro</title>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

:root {
  --ink: #111827;
  --ink2: #1f2d3d;
  --ink3: #5a6a7e;
  --accent: #e07b10;
  --accent-dark: #b85e05;
  --navy: #153047;
  --navy2: #1a3d5c;
  --surface: #f4f6f9;
  --white: #ffffff;
  --border: #e2e8f0;
  --success: #128C7E;
  --success-bg: #e8f7f2;
  --warning: #92400e;
  --warning-bg: #fffbeb;
  --error: #c0392b;
  --error-bg: #fdf0ee;
  --shadow: 0 4px 24px rgba(17,24,39,0.10);
  --radius: 14px;
  --radius-sm: 8px;
}

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--surface);
  color: var(--ink);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

header {
  background: var(--navy2);
  padding: 18px 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.logo {
  display: flex;
  align-items: center;
  gap: 12px;
  text-decoration: none;
}

.logo-mark {
  width: 38px;
  height: 38px;
  background: var(--accent);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-mark svg {
  width: 22px;
  height: 22px;
}

.logo-text {
  color: white;
  font-size: 17px;
  font-weight: 700;
}

.logo-text span {
  color: #f5a623;
}

.header-contact {
  color: rgba(255,255,255,0.65);
  font-size: 13px;
}

.header-contact a {
  color: #f5a623;
  text-decoration: none;
  font-weight: 600;
}

.hero {
  background: var(--navy);
  padding: 40px 32px 56px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: -80px;
  left: 50%;
  transform: translateX(-50%);
  width: 650px;
  height: 320px;
  background: radial-gradient(ellipse, rgba(224,123,16,0.24) 0%, transparent 70%);
}

.hero h1 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(28px, 5vw, 42px);
  color: white;
  line-height: 1.18;
  margin-bottom: 10px;
  position: relative;
}

.hero h1 em {
  color: #f5a623;
}

.hero p {
  color: rgba(255,255,255,0.72);
  font-size: 15px;
  max-width: 560px;
  margin: 0 auto;
  line-height: 1.6;
  position: relative;
}

.trust-badges {
  display: flex;
  gap: 14px;
  justify-content: center;
  margin-top: 24px;
  flex-wrap: wrap;
  position: relative;
}

.trust-badge {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 20px;
  padding: 7px 14px;
  font-size: 12px;
  color: rgba(255,255,255,0.82);
}

.progress-wrap {
  background: white;
  border-bottom: 1px solid var(--border);
  padding: 0 24px;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.progress-steps {
  display: flex;
  max-width: 760px;
  margin: 0 auto;
}

.step-tab {
  flex: 1;
  padding: 16px 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-size: 13px;
  color: #9aa8b5;
  border-bottom: 2px solid transparent;
}

.step-tab.active {
  color: var(--accent);
  border-bottom-color: var(--accent);
}

.step-tab.done {
  color: var(--ink3);
}

.step-num {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: #e8f0ed;
  font-size: 11px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-tab.active .step-num,
.step-tab.done .step-num {
  background: var(--accent);
  color: white;
}

main {
  flex: 1;
  padding: 32px 16px 60px;
}

.form-card {
  background: white;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  max-width: 760px;
  margin: 0 auto;
  overflow: hidden;
}

.form-step {
  display: none;
}

.form-step.active {
  display: block;
}

.step-header {
  padding: 28px 32px 20px;
  border-bottom: 1px solid var(--border);
}

.step-header h2 {
  font-family: 'DM Serif Display', serif;
  font-size: 24px;
  color: var(--ink);
  margin-bottom: 5px;
}

.step-header p {
  color: var(--ink3);
  font-size: 14px;
  line-height: 1.5;
}

.step-body {
  padding: 28px 32px;
}

.type-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}

.type-card {
  border: 2px solid var(--border);
  border-radius: var(--radius);
  padding: 24px 20px;
  cursor: pointer;
  text-align: center;
  transition: 0.18s;
  position: relative;
}

.type-card:hover {
  border-color: #fdd9a8;
  background: #fff4e6;
}

.type-card.selected {
  border-color: var(--accent);
  background: #fff4e6;
}

.type-card.selected::after {
  content: '✓';
  position: absolute;
  top: 10px;
  right: 12px;
  width: 20px;
  height: 20px;
  background: var(--accent);
  color: white;
  border-radius: 50%;
  font-size: 11px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

.type-icon {
  font-size: 34px;
  margin-bottom: 10px;
  display: block;
}

.type-name {
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 4px;
}

.type-desc {
  font-size: 12px;
  color: var(--ink3);
  line-height: 1.45;
}

.field {
  margin-bottom: 20px;
}

.field label {
  display: block;
  font-size: 13px;
  font-weight: 700;
  color: var(--ink2);
  margin-bottom: 7px;
}

.req {
  color: var(--accent);
}

.field input,
.field select,
.field textarea {
  width: 100%;
  padding: 12px 14px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  color: var(--ink);
  background: white;
  outline: none;
}

.field textarea {
  min-height: 84px;
  resize: vertical;
}

.field input:focus,
.field select:focus,
.field textarea:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(224,123,16,0.12);
}

.field input.error,
.field select.error {
  border-color: var(--error);
}

.hint {
  font-size: 12px;
  color: var(--ink3);
  margin-top: 5px;
}

.error-msg {
  font-size: 12px;
  color: var(--error);
  margin-top: 5px;
  display: none;
}

.error-msg.show {
  display: block;
}

.field-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}

.price-panel {
  background: #fff4e6;
  border: 1.5px solid #fdd9a8;
  border-radius: var(--radius);
  padding: 18px 20px;
  margin-top: 10px;
}

.price-title {
  font-size: 13px;
  font-weight: 800;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 12px;
}

.price-big {
  font-size: 32px;
  font-weight: 800;
  color: var(--accent);
  margin-bottom: 5px;
}

.price-note {
  font-size: 13px;
  color: var(--ink3);
  line-height: 1.45;
}

.review-box {
  background: var(--warning-bg);
  border: 1px solid #fde68a;
  color: var(--warning);
  border-radius: var(--radius-sm);
  padding: 12px 14px;
  font-size: 13px;
  line-height: 1.45;
  margin-top: 10px;
}

.date-info {
  background: var(--warning-bg);
  border: 1px solid #fde68a;
  border-radius: var(--radius-sm);
  padding: 12px 16px;
  font-size: 13px;
  color: var(--warning);
  margin-bottom: 20px;
  line-height: 1.5;
}

.days-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

.day-slot {
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 12px 8px;
  text-align: center;
  cursor: pointer;
  transition: 0.15s;
}

.day-slot:hover {
  border-color: #fdd9a8;
  background: #fff4e6;
}

.day-slot.selected {
  border-color: var(--accent);
  background: #fff4e6;
}

.day-name {
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  color: var(--ink3);
}

.day-date {
  font-size: 19px;
  font-weight: 800;
  color: var(--ink);
  margin: 3px 0;
}

.day-month {
  font-size: 11px;
  color: var(--ink3);
}

.window-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-top: 18px;
}

.window-card {
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 14px 12px;
  text-align: center;
  cursor: pointer;
}

.window-card:hover,
.window-card.selected {
  border-color: var(--accent);
  background: #fff4e6;
}

.window-card strong {
  display: block;
  color: var(--ink);
  font-size: 15px;
}

.window-card span {
  display: block;
  color: var(--ink3);
  font-size: 12px;
  margin-top: 4px;
}

.confirm-block {
  background: var(--surface);
  border-radius: var(--radius-sm);
  padding: 18px 20px;
  margin-bottom: 16px;
}

.confirm-block-label {
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--accent);
  margin-bottom: 12px;
}

.confirm-item {
  display: flex;
  gap: 10px;
  margin-bottom: 10px;
  font-size: 14px;
}

.confirm-item:last-child {
  margin-bottom: 0;
}

.ci-label {
  color: var(--ink3);
  min-width: 120px;
  flex-shrink: 0;
}

.ci-value {
  font-weight: 600;
  color: var(--ink);
  line-height: 1.4;
}

.terms-check {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  margin: 20px 0;
  cursor: pointer;
}

.terms-check input {
  width: 18px;
  height: 18px;
  accent-color: var(--accent);
  margin-top: 2px;
}

.terms-check span {
  font-size: 13px;
  color: var(--ink3);
  line-height: 1.5;
}

.status-box {
  display: none;
  border-radius: var(--radius-sm);
  padding: 12px 14px;
  font-size: 13px;
  line-height: 1.45;
  margin-bottom: 16px;
}

.status-box.show {
  display: block;
}

.status-box.error {
  background: var(--error-bg);
  border: 1px solid #f3bbb4;
  color: var(--error);
}

.status-box.success {
  background: var(--success-bg);
  border: 1px solid #a4ddcc;
  color: var(--success);
}

.btn-row {
  display: flex;
  gap: 12px;
  align-items: center;
  padding: 20px 32px 28px;
  border-top: 1px solid var(--border);
}

.btn {
  padding: 14px 24px;
  border-radius: var(--radius-sm);
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  font-weight: 800;
  cursor: pointer;
  border: none;
  transition: 0.15s;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.btn-primary {
  background: var(--accent);
  color: white;
  flex: 1;
  justify-content: center;
}

.btn-primary:hover {
  background: var(--accent-dark);
}

.btn-back {
  background: transparent;
  color: var(--ink3);
  border: 1.5px solid var(--border);
}

.btn-back:hover {
  background: var(--surface);
}

.btn:disabled {
  opacity: 0.55;
  cursor: not-allowed;
}

.success-screen {
  padding: 48px 32px;
  text-align: center;
}

.success-icon {
  width: 72px;
  height: 72px;
  background: #fff4e6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24px;
  color: var(--accent);
  font-size: 34px;
}

.success-screen h2 {
  font-family: 'DM Serif Display', serif;
  font-size: 28px;
  margin-bottom: 10px;
}

.success-screen p {
  color: var(--ink3);
  font-size: 15px;
  line-height: 1.6;
  max-width: 460px;
  margin: 0 auto 24px;
}

.booking-ref {
  background: #fff4e6;
  border: 1.5px solid #fdd9a8;
  border-radius: var(--radius-sm);
  padding: 16px 24px;
  display: inline-block;
  margin-bottom: 24px;
}

.booking-ref-label {
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--accent);
  margin-bottom: 4px;
}

.booking-ref-num {
  font-size: 22px;
  font-weight: 800;
  color: var(--ink);
  font-family: monospace;
  letter-spacing: 2px;
}

footer {
  background: var(--navy2);
  padding: 20px 32px;
  text-align: center;
  color: rgba(255,255,255,0.48);
  font-size: 12px;
  margin-top: auto;
}

footer a {
  color: #f5a623;
  text-decoration: none;
}

@media(max-width:560px) {
  header {
    padding: 14px 16px;
  }

  .header-contact {
    display: none;
  }

  .hero {
    padding: 28px 16px 40px;
  }

  .step-body,
  .step-header {
    padding: 20px 16px;
  }

  .btn-row {
    padding: 16px;
  }

  .type-cards,
  .field-row,
  .window-grid {
    grid-template-columns: 1fr;
  }

  .days-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .step-label {
    display: none;
  }
}
</style>
</head>

<body>
<header>
  <a href="https://theepc.pro" class="logo">
    <div class="logo-mark">
      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round">
        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
    </div>
    <span class="logo-text">The EPC<span>.pro</span></span>
  </a>
  <div class="header-contact">Questions? <a href="tel:07831363622">07831 363 622</a></div>
</header>

<div class="hero">
  <h1>Book your EPC<br><em>assessment online</em></h1>
  <p>Fast, professional energy performance certificates for London properties. Domestic bookings and commercial quote reviews are sent straight into the EPC Pro dashboard.</p>
  <div class="trust-badges">
    <div class="trust-badge">Fully accredited DEA</div>
    <div class="trust-badge">London coverage</div>
    <div class="trust-badge">AM/PM booking windows</div>
  </div>
</div>

<div class="progress-wrap" id="progress-wrap">
  <div class="progress-steps">
    <div class="step-tab active" id="tab-1"><div class="step-num">1</div><span class="step-label">Service</span></div>
    <div class="step-tab" id="tab-2"><div class="step-num">2</div><span class="step-label">Property</span></div>
    <div class="step-tab" id="tab-3"><div class="step-num">3</div><span class="step-label">Date</span></div>
    <div class="step-tab" id="tab-4"><div class="step-num">4</div><span class="step-label">Contact</span></div>
    <div class="step-tab" id="tab-5"><div class="step-num">5</div><span class="step-label">Confirm</span></div>
  </div>
</div>

<main>
<div class="form-card">

  <div class="form-step active" id="step-1">
    <div class="step-header">
      <h2>What type of EPC do you need?</h2>
      <p>Choose domestic or commercial so we can route the enquiry correctly.</p>
    </div>
    <div class="step-body">
      <div class="type-cards">
        <div class="type-card" id="card-domestic" onclick="selectType('Domestic')">
          <span class="type-icon">🏠</span>
          <div class="type-name">Domestic EPC</div>
          <div class="type-desc">Houses, flats, landlords, homeowners and estate agents. From £60.</div>
        </div>
        <div class="type-card" id="card-commercial" onclick="selectType('Commercial')">
          <span class="type-icon">🏢</span>
          <div class="type-name">Commercial EPC</div>
          <div class="type-desc">Shops, offices, warehouses and non-domestic premises. Review before booking.</div>
        </div>
      </div>
    </div>
    <div class="btn-row">
      <button class="btn btn-primary" onclick="goToStep(2)">Continue →</button>
    </div>
  </div>

  <div class="form-step" id="step-2">
    <div class="step-header">
      <h2>Property details</h2>
      <p>We use this to calculate your quote and check the correct booking route.</p>
    </div>
    <div class="step-body">
      <div class="field">
        <label>Property address <span class="req">*</span></label>
        <input type="text" id="address" placeholder="e.g. 14 Highbury Grove">
        <div class="error-msg" id="err-address">Please enter the property address</div>
      </div>

      <div class="field-row">
        <div class="field">
          <label>Postcode <span class="req">*</span></label>
          <input type="text" id="postcode" placeholder="e.g. N5 1PF" oninput="checkPostcode()" style="text-transform:uppercase">
          <div class="error-msg" id="err-postcode">Please enter a postcode</div>
          <div class="hint" id="postcode-hint">Enter a London postcode.</div>
        </div>

        <div class="field">
          <label>Property type</label>
          <select id="property_type">
            <option value="">— Select —</option>
            <option>Flat / Apartment</option>
            <option>Terraced house</option>
            <option>Semi-detached</option>
            <option>Detached house</option>
            <option>Bungalow</option>
            <option>Shop</option>
            <option>Office</option>
            <option>Warehouse</option>
            <option>Other</option>
          </select>
        </div>
      </div>

      <div id="domestic-fields" style="display:none">
        <div class="field">
          <label>Estimated property value <span class="req">*</span></label>
          <select id="property_value" onchange="refreshQuote()">
            <option value="">— Select —</option>
            <option value="999000">Up to £999,000</option>
            <option value="1500000">£1,000,000 to £1,999,999</option>
            <option value="2500000">£2,000,000 to £2,999,999</option>
            <option value="3500000">£3,000,000 to £3,999,999</option>
            <option value="4000001">Over £4,000,000</option>
          </select>
          <div class="error-msg" id="err-property-value">Please select the property value band</div>
        </div>

        <div class="field" id="domestic-size-field" style="display:none">
          <label>Approximate floor area m² <span class="req">*</span></label>
          <input type="number" min="1" id="domestic_sqm" placeholder="e.g. 180" oninput="refreshQuote()">
          <div class="hint">Required for properties over £4,000,000.</div>
          <div class="error-msg" id="err-domestic-sqm">Please enter approximate square meterage</div>
        </div>
      </div>

      <div id="commercial-fields" style="display:none">
        <div class="field">
          <label>Approximate commercial floor area m² <span class="req">*</span></label>
          <input type="number" min="1" id="commercial_sqm" placeholder="e.g. 250" oninput="refreshQuote()">
          <div class="error-msg" id="err-commercial-sqm">Please enter the commercial floor area</div>
          <div class="hint">901 m² and above will be treated as a custom quote / review.</div>
        </div>
      </div>

      <div class="field">
        <label>Notes / access information</label>
        <textarea id="notes" placeholder="Tenant details, parking, agent details, preferred times, special access notes"></textarea>
      </div>

      <div class="price-panel" id="quote-panel">
        <div class="price-title">Quote</div>
        <div class="price-big" id="quote-price">—</div>
        <div class="price-note" id="quote-note">Complete the property details to calculate the quote.</div>
      </div>
    </div>

    <div class="btn-row">
      <button class="btn btn-back" onclick="goToStep(1)">← Back</button>
      <button class="btn btn-primary" onclick="goToStep(3)">Continue →</button>
    </div>
  </div>

  <div class="form-step" id="step-3">
    <div class="step-header">
      <h2 id="date-heading">Choose a booking window</h2>
      <p id="date-subtitle">Domestic clients choose AM or PM only. Exact ETA is allocated later.</p>
    </div>
    <div class="step-body">
      <div class="date-info">
        <strong>Area:</strong> <span id="zone-name">London</span> &nbsp;|&nbsp;
        <strong>Booking type:</strong> <span id="booking-type-note">AM/PM booking window</span>
      </div>

      <div class="days-grid" id="days-grid"></div>

      <div class="window-grid" id="window-grid">
        <div class="window-card" id="window-AM" onclick="selectWindow('AM')">
          <strong>AM</strong>
          <span>08:00 to 13:00</span>
        </div>
